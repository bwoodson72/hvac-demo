# Copy this file to .env.local and fill in the values.
# Get these from https://sanity.io/manage → your project → API

NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"

# Create a token at: sanity.io/manage → your project → API → Tokens
# Viewer role is sufficient for read-only preview
SANITY_API_READ_TOKEN=""

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Preview / Visual Editing
# SANITY_REVALIDATION_SECRET is sent as the "sanity-webhook-secret" header by
# your Sanity webhook (sanity.io/manage → project → API → Webhooks).
# Generate a random string: openssl rand -hex 32
SANITY_REVALIDATION_SECRET=""

# Contact form email delivery via Resend (https://resend.com)
# Leave RESEND_API_KEY empty to log submissions to the console instead of sending emails.
RESEND_API_KEY=""
CONTACT_EMAIL_TO="hello@example.com"
CONTACT_EMAIL_FROM="noreply@yourdomain.com"
